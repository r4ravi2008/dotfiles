{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-opus-4.6",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.3-codex": {
          "limit": {
            "context": 250000,
            "output": 65536
          }
        },
        "gpt-5.2": {
          "limit": {
            "context": 250000,
            "output": 65536
          }
        }
      }
    },
    "github-copilot": {
      "models": {
        "gpt-5.2": {
          "limit": {
            "context": 250000,
            "output": 65536
          }
        },
        "gpt-5.2-codex": {
          "limit": {
            "context": 250000,
            "output": 65536
          }
        },
        "claude-opus-4.5": {
          "limit": {
            "context": 200000,
            "output": 32768
          }
        }
      }
    }
  },
  "mcp": {
    "DAST-Orch": {
      "type": "remote",
      "url": "http://127.0.0.1:53333/mcp/stream",
      "enabled": true
    }
  },
  "agent": {
    "build": {
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "task": "allow",
        "external_directory": {
          "/tmp*": "allow"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow"
      }
    }
  }
}
